# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# ── Node / Next.js ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/tsconfig.tsbuildinfo

# ── Local scripts (root-level only) ──────────────────────────────────────────
/*.py

# ── ML artifacts (large binaries — never commit) ──────────────────────────────
models/
# Allow Next.js route folders named "models" inside the frontend
!frontend/app/**/models/
!frontend/app/**/models/**
outputs/
exports/
checkpoints/
*.bin
*.safetensors
*.pt
*.pth
*.gguf
*.ggml

# ── Datasets ──────────────────────────────────────────────────────────────────
datasets/
# Allow Next.js route folders named "datasets" inside the frontend
!frontend/app/**/datasets/
!frontend/app/**/datasets/**
data/
*.jsonl
*.parquet
*.arrow

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Runtime data (bind-mount dirs — never commit) ─────────────────────────────
data/
outputs/
backups/

# ── Logs & caches ─────────────────────────────────────────────────────────────
logs/
*.log
.cache/
runs/
wandb/
mlruns/
tensorboard_logs/
.ipynb_checkpoints/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
