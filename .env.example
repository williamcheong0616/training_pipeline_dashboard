# ── Ports (override to avoid conflicts on the workstation) ────────────────────
API_PORT=8000
FRONTEND_PORT=3000
FLOWER_PORT=5555

# ── Service URLs ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed browser origins for CORS.
# Add your workstation's LAN IP so teammates can connect from other machines:
#   FRONTEND_URL=http://localhost:3000,http://192.168.1.x:3000
FRONTEND_URL=http://localhost:3000

# ── Storage directories (relative to project root) ───────────────────────────
MODELS_DIR=./models
DATASETS_DIR=./datasets
EXPORTS_DIR=./exports

# ── HuggingFace token (required for gated models such as LLaMA / Gemma) ──────
HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Flower task monitor credentials ──────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme

# ── Log level (uvicorn + celery): debug | info | warning | error ──────────────
LOG_LEVEL=info
